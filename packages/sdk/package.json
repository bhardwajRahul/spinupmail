{
  "name": "spinupmail",
  "version": "0.1.1",
  "description": "SpinupMail TypeScript SDK for creating and reading temporary email addresses.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "typecheck": "tsgo --noEmit -p tsconfig.test.json && tsgo --noEmit -p tests/tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "test:package": "node ./scripts/smoke-package.mjs"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.11",
    "@typescript/native-preview": "7.0.0-dev.20260222.1",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3"
  }
}
