{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "*": ["./*"],
      "@/*": ["./src/*"]
    },
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "tsBuildInfoFile": "./node_modules/.tsbuildinfo.landing"
  },
  "include": ["src", "src/env.d.ts", "worker-configuration.d.ts"]
}
