{
  "name": "@spinupmail/backend",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsgo --noEmit",
    "deploy": "pnpm run db:migrate:prod && pnpm exec wrangler deploy --minify",
    "cf-typegen": "pnpm exec wrangler types --env-interface CloudflareBindings",
    "auth:generate": "npx --yes @better-auth/cli@latest generate --config src/auth/cli.ts --output src/db/auth.schema.ts -y",
    "auth:format": "npx --yes prettier --write src/db/auth.schema.ts",
    "auth:update": "pnpm run auth:generate && pnpm run auth:format",
    "db:generate": "drizzle-kit generate",
    "db:migrate:dev": "pnpm exec wrangler d1 migrations apply SUM_DB --local",
    "db:migrate:prod": "CI=1 pnpm exec wrangler d1 migrations apply SUM_DB --remote",
    "db:studio:dev": "drizzle-kit studio",
    "db:studio:prod": "NODE_ENV=production drizzle-kit studio",
    "test:unit": "pnpm exec vitest run --config vitest.unit.config.ts",
    "test:integration": "pnpm exec vitest run --config vitest.integration.config.ts",
    "test:integration:workers": "pnpm exec vitest run --config vitest.workers.config.ts"
  },
  "dependencies": {
    "@cloudflare/workers-types": "4.20260207.0",
    "@hono/zod-validator": "^0.7.5",
    "better-auth": "^1.4.18",
    "better-auth-cloudflare": "^0.2.9",
    "drizzle-orm": "^0.44.5",
    "hono": "^4.11.10",
    "postal-mime": "^2.7.3",
    "resend": "^6.9.2",
    "sanitize-html": "^2.17.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.12",
    "@spinupmail/contracts": "workspace:*",
    "@types/node": "^22.15.30",
    "@types/sanitize-html": "^2.16.0",
    "@typescript/native-preview": "7.0.0-dev.20260222.1",
    "@vitest/coverage-v8": "3.2.4",
    "drizzle-kit": "^0.31.1",
    "fast-check": "^4.5.3",
    "typescript": "^5.8.3",
    "vitest": "3.2.4",
    "wrangler": "^4.4.0"
  }
}
