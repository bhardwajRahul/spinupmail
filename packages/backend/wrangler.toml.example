# Example Wrangler config
# Make a copy of this file and name it as `wrangler.toml`
# Replace placeholder IDs with your Cloudflare resource IDs.

name = "spinupmail"
main = "src/index.ts"
compatibility_date = "2025-03-01"
compatibility_flags = ["nodejs_compat"]

[observability]
enabled = true

[placement]
mode = "smart"

[[migrations]]
tag = "v1"
new_sqlite_classes = ["InboundAbuseCounterDurableObject"]

[[durable_objects.bindings]]
name = "ABUSE_COUNTERS"
class_name = "InboundAbuseCounterDurableObject"

[[d1_databases]]
binding = "SUM_DB"
database_name = "SUM_DB"
database_id = "YOUR_D1_DATABASE_ID"
migrations_dir = "drizzle"

[[kv_namespaces]]
binding = "SUM_KV"
id = "YOUR_KV_NAMESPACE_ID"

[[r2_buckets]]
binding = "R2_BUCKET"
bucket_name = "YOUR_R2_BUCKET_NAME"
# Optional for local/preview
preview_bucket_name = "YOUR_R2_PREVIEW_BUCKET_NAME"

[[send_email]]
name = "EMAIL"

[vars]
EMAIL_DOMAINS = "example.com,example-test.com"
FORCED_MAIL_PREFIX = "" # e.g. if set to "temp", all addresses will start with "temp-"
AUTH_ALLOWED_EMAIL_DOMAIN = "example.com"
MAX_ADDRESSES_PER_ORGANIZATION = "100"
MAX_RECEIVED_EMAILS_PER_ORGANIZATION = "1000"
MAX_RECEIVED_EMAILS_PER_ADDRESS = "100"
API_KEY_RATE_LIMIT_WINDOW = "60"
API_KEY_RATE_LIMIT_MAX = "120"
AUTH_RATE_LIMIT_WINDOW = "60"
# Optional: set to override Better Auth's default global max
AUTH_RATE_LIMIT_MAX = "100"
AUTH_CHANGE_EMAIL_RATE_LIMIT_WINDOW = "3600"
AUTH_CHANGE_EMAIL_RATE_LIMIT_MAX = "2"
RESEND_FROM_EMAIL = "Spinupmail <verify@example.com>"
# Configure secrets via `wrangler secret put`:
# BETTER_AUTH_SECRET, BETTER_AUTH_BASE_URL, GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, RESEND_API_KEY, TURNSTILE_SECRET_KEY
EMAIL_FORWARD_TO = ""
EMAIL_MAX_BYTES = "524288"
# Max body text/html bytes persisted per email row (oversized bodies are dropped)
EMAIL_BODY_MAX_BYTES = "524288"
EMAIL_ATTACHMENT_MAX_BYTES = "10485760"
# Cap total stored email attachment bytes per organization; defaults to 104857600 (100MB).
# New attachments are skipped once the organization would exceed this quota.
EMAIL_ATTACHMENT_MAX_TOTAL_BYTES_PER_ORGANIZATION = "104857600"
# Set to "false" to ignore inbound attachments and disable attachment download/UI surfaces
EMAIL_ATTACHMENTS_ENABLED = "true"
# Storage optimization flags (default false when unset)
EMAIL_STORE_HEADERS_IN_DB = "false"
EMAIL_STORE_RAW_IN_DB = "false"
# Optional debug mode: store raw MIME in private R2 for authenticated retrieval
EMAIL_STORE_RAW_IN_R2 = "false"
