# Example Wrangler config
# Make a copy of this file and name it as `wrangler.toml`
# Replace placeholder IDs with your Cloudflare resource IDs.

name = "spinupmail"
main = "src/index.ts"
compatibility_date = "2025-03-01"
compatibility_flags = ["nodejs_compat"]

[observability]
enabled = true

[placement]
mode = "smart"

[[d1_databases]]
binding = "SUM_DB"
database_name = "SUM_DB"
database_id = "YOUR_D1_DATABASE_ID"
migrations_dir = "drizzle"

[[kv_namespaces]]
binding = "SUM_KV"
id = "YOUR_KV_NAMESPACE_ID"
