{
  "name": "spinupmail",
  "private": true,
  "scripts": {
    "dev:backend": "pnpm -C packages/backend dev",
    "build:backend": "pnpm -C packages/backend build",
    "deploy:backend": "pnpm -C packages/backend deploy",
    "cf-typegen": "pnpm -C packages/backend cf-typegen",
    "auth:update": "pnpm -C packages/backend auth:update",
    "db:generate": "pnpm -C packages/backend db:generate",
    "db:migrate:dev": "pnpm -C packages/backend db:migrate:dev",
    "db:migrate:prod": "pnpm -C packages/backend db:migrate:prod",
    "db:studio:dev": "pnpm -C packages/backend db:studio:dev",
    "db:studio:prod": "pnpm -C packages/backend db:studio:prod",
    "dev:frontend": "pnpm -C packages/frontend dev",
    "build:frontend": "pnpm -C packages/frontend build",
    "typecheck:backend": "pnpm -C packages/backend typecheck",
    "typecheck:frontend": "pnpm -C packages/frontend typecheck",
    "typecheck:landing": "pnpm -C packages/landing typecheck",
    "deploy:frontend": "pnpm -C packages/frontend deploy",
    "test:unit": "pnpm -C packages/backend test:unit && pnpm -C packages/frontend test:unit",
    "test:landing": "pnpm -C packages/landing test",
    "test:integration": "pnpm -C packages/backend test:integration",
    "test:component": "pnpm -C packages/frontend test:component",
    "test:e2e": "pnpm -C packages/e2e test",
    "test:ci": "pnpm run lint && pnpm run build:backend && pnpm run typecheck:frontend && pnpm run typecheck:landing && pnpm run test:unit && pnpm run test:landing && pnpm run test:integration && pnpm run test:component && pnpm run test:e2e",
    "dev:landing": "pnpm -C packages/landing dev",
    "build:landing": "pnpm -C packages/landing build",
    "deploy:landing": "pnpm -C packages/landing deploy",
    "lint": "pnpm run lint:root && pnpm run lint:landing",
    "lint:backend": "eslint packages/backend",
    "lint:landing": "pnpm -C packages/landing exec eslint .",
    "lint:root": "eslint packages/backend packages/frontend eslint.config.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.9.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "packages/{backend,frontend}/**/*.{js,mjs,cjs,ts,tsx}": [
      "pnpm exec eslint --quiet --fix --no-warn-ignored"
    ],
    "eslint.config.mjs": [
      "pnpm exec eslint --quiet --fix --no-warn-ignored"
    ],
    "packages/landing/**/*.{js,mjs,cjs,ts,tsx}": [
      "pnpm -C packages/landing exec eslint --fix --no-warn-ignored"
    ],
    "**/*.{js,mjs,cjs,ts,tsx,jsx,json,css,md,html}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "^0.45.1"
    }
  }
}
